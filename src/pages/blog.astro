---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/sections/Footer.astro';

// Leer posts desde JSON para que el bot pueda editarlo via GitHub API
const postsRaw = await import('../data/blog-posts.json', { assert: { type: 'json' } });
const posts = postsRaw.default;
---

<Layout title="HermesCraft Blog — La Crónica">
  <main class="bg-sky text-ink">
    <Nav />

    <header class="pt-24 pb-12">
      <div class="container-narrow text-center">
        <div class="inline-flex items-center gap-2 bg-cream/90 border-2 border-ink/20 px-3 py-1.5 shadow-pixel mb-6">
          <span class="w-2 h-2 bg-hermes animate-pulse"></span>
          <span class="font-mono text-[10px] uppercase tracking-widest text-ink">Blog</span>
        </div>
        <h1 class="h-display text-mc text-cream mb-4">
          La <span class="text-hermes">Crónica</span> del Swarm
        </h1>
        <p class="font-sans text-lg text-ink max-w-xl mx-auto bg-cream/90 border-2 border-ink/20 p-4 shadow-pixel">
          Construimos en público. Compartimos lo que aprendemos, lo que falla, y lo que viene.
        </p>
      </div>
    </header>

    <section class="pb-20">
      <div class="container-narrow">
        <div class="space-y-8">
          {posts.map((p: any) => (
            <article class={`mc-card hover:border-hermes/40 transition-colors group cursor-pointer ${p.highlight ? 'border-hermes/60' : ''}`}>
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span class="font-mono text-[9px] uppercase tracking-wider px-2 py-0.5 bg-hermes/10 text-ink border border-hermes/20">
                  {p.tag}
                </span>
                <span class="font-mono text-[10px] text-ink/50">{p.date}</span>
                {p.highlight && (
                  <span class="font-mono text-[9px] uppercase tracking-wider px-2 py-0.5 bg-grass text-cream border border-grass-dark">
                    Destacado
                  </span>
                )}
              </div>
              <h2 class="font-serif font-bold text-xl md:text-2xl text-ink group-hover:text-hermes transition-colors">
                {p.title}
              </h2>
              <p class="text-sm md:text-base text-ink/70 mt-2 leading-relaxed">{p.excerpt}</p>
              <div class="mt-4 font-mono text-[10px] text-hermes/70 group-hover:text-hermes">
                Leer más →
              </div>
            </article>
          ))}
        </div>

        <div class="mt-16 text-center">
          <div class="inline-block bg-cream/90 border-2 border-ink/20 p-6 shadow-pixel">
            <p class="font-mono text-xs text-ink mb-3">
              Suscribite vía Telegram
            </p>
            <p class="font-sans text-lg text-ink">
              <span class="text-hermes font-bold">@hermesdaemoncraft_bot</span>
            </p>
            <p class="font-mono text-[10px] text-ink/50 mt-2">
              El bot también escribe. No solo responde.
            </p>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
